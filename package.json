{
  "name": "svelte-voidmorphism",
  "version": "0.1.0",
  "description": "Voidmorphism — a cinematic, space-inspired Svelte 5 material system where interfaces appear carved from refractive void matter. Includes a full component suite plus morphing/glitch transitions, built with runes.",
  "license": "MIT",
  "author": "",
  "keywords": [
    "svelte",
    "svelte5",
    "svelte-kit",
    "voidmorphism",
    "glassmorphism",
    "liquid-glass",
    "material",
    "design-system",
    "ui",
    "components",
    "refraction",
    "animation",
    "transition",
    "morph",
    "glitch",
    "runes",
    "svelte-library"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/svelte-voidmorphism.git"
  },
  "homepage": "https://github.com/yourusername/svelte-voidmorphism#readme",
  "bugs": {
    "url": "https://github.com/yourusername/svelte-voidmorphism/issues"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "package": "svelte-kit sync && svelte-package && publint",
    "prepublishOnly": "npm run package",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^3.3.1",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/package": "^2.3.7",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.0",
    "jsdom": "^25.0.1",
    "publint": "^0.2.12",
    "svelte": "^5.2.0",
    "svelte-check": "^4.1.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./transitions": {
      "types": "./dist/transitions/index.d.ts",
      "svelte": "./dist/transitions/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "svelte": "./dist/utils/index.js"
    },
    "./styles": "./dist/styles/voidmorphism.css",
    "./styles/voidmorphism.css": "./dist/styles/voidmorphism.css"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module"
}
