{
  "name": "svelte-spacemorphism",
  "version": "0.1.0",
  "description": "Spacemorphism — a monochrome, gravity-driven, space sci-fi Svelte 5 material system and animated-component suite. The successor to glassmorphism and liquid glass: surfaces lens light, bend reality, and pull star dust toward the cursor. Built with runes, zero runtime dependencies.",
  "license": "MIT",
  "author": "",
  "keywords": [
    "svelte",
    "svelte5",
    "svelte-kit",
    "spacemorphism",
    "glassmorphism",
    "liquid-glass",
    "space",
    "gravity",
    "webgl",
    "material",
    "design-system",
    "ui",
    "components",
    "refraction",
    "animation",
    "transition",
    "particles",
    "starfield",
    "runes",
    "svelte-library"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/svelte-spacemorphism.git"
  },
  "homepage": "https://github.com/yourusername/svelte-spacemorphism#readme",
  "bugs": {
    "url": "https://github.com/yourusername/svelte-spacemorphism/issues"
  },
  "bin": {
    "svelte-spacemorphism": "cli/index.js",
    "spacemorphism": "cli/index.js"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "registry": "node cli/registry-build.js",
    "package": "npm run registry && svelte-kit sync && svelte-package && publint",
    "prepublishOnly": "npm run package",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^3.3.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/package": "^2.3.7",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.0",
    "jsdom": "^25.0.1",
    "publint": "^0.2.12",
    "svelte": "^5.2.0",
    "svelte-check": "^4.1.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./transitions": {
      "types": "./dist/transitions/index.d.ts",
      "svelte": "./dist/transitions/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "svelte": "./dist/utils/index.js"
    },
    "./styles": "./dist/styles/spacemorphism.css",
    "./styles/spacemorphism.css": "./dist/styles/spacemorphism.css"
  },
  "files": [
    "dist",
    "cli",
    "registry.json",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module"
}
